# ============================================
# PENSADERO - FRONTEND ENVIRONMENT CONFIG
# ============================================
# Copia este archivo como .env y ajusta los valores.
# Uso personal single-user: no hay auth ni Supabase.

# URL base del backend Node (sin barra final)
VITE_API_URL=http://localhost:5000

# URL del WebSocket para progreso en tiempo real
VITE_WS_URL=ws://localhost:5000/ws
