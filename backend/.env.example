# ============================================
# PENSADERO - Configuración de entorno
# ============================================
# Copia este archivo como `.env` y ajusta los valores a tu máquina.
# `.env` NO debe subirse a control de versiones.

# Puerto en el que escucha el servidor HTTP/WebSocket
PORT=5000

# Directorio raíz por defecto si scan_paths.json está vacío.
# Déjalo vacío en distribución; añade rutas desde la UI cuando arranques.
# Ejemplo Windows: C:\TOOLS\Pensadero\biblioteca
# Ejemplo Linux/Mac: /home/user/Pensadero
CONTENT_DIR=

# URL pública del servidor (sin barra final). Se usa para construir
# URLs de thumbnails y streaming en las respuestas de la API.
SERVER_URL=http://localhost:5000

# Host de Ollama (búsqueda en lenguaje natural sobre tags y metadatos)
OLLAMA_HOST=http://localhost:11434

# Modelo Ollama para parsear consultas naturales.
# Recomendados:
#   - qwen2.5:14b-instruct  → calidad alta, ~9 GB VRAM (default; PC nuevo OK)
#   - qwen2.5:7b-instruct   → más rápido, ~5 GB VRAM
#   - llama3.1:8b           → fallback genérico, peor en español/JSON
# Descargar con: ollama pull <modelo>
# Pensadero arranca y funciona sin Ollama; solo cae el modo "Natural".
OLLAMA_MODEL=qwen2.5:14b-instruct

PERSONS_REGISTRY=
# Ruta absoluta al people_registry.json. Si está vacío, no se resuelven display_name ni avatares.
# Ej recomendado: C:\TOOLS\Pensadero\data\people_registry.json

PERSONS_AVATARS_BASE=
# Opcional. Carpeta base para avatar_path relativos. Si está vacío, se deriva de dirname(PERSONS_REGISTRY).
