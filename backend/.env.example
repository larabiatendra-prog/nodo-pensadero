# ============================================
# PENSADERO - Configuración de entorno
# ============================================
# Copia este archivo como `.env` y ajusta los valores a tu máquina.
# `.env` NO debe subirse a control de versiones.

# Puerto en el que escucha el servidor HTTP/WebSocket
PORT=5000

# Directorio raíz por defecto si scan_paths.json está vacío.
# Déjalo vacío en distribución; añade rutas desde la UI cuando arranques.
# Ejemplo Windows: C:\TOOLS\Pensadero\biblioteca
# Ejemplo Linux/Mac: /home/user/Pensadero
CONTENT_DIR=

# URL pública del servidor (sin barra final). Se usa para construir
# URLs de thumbnails y streaming en las respuestas de la API.
SERVER_URL=http://localhost:5000

# Host de Ollama (búsqueda en lenguaje natural y escaneo visual)
OLLAMA_HOST=http://localhost:11434

# Modelo Ollama para parsear consultas naturales y re-ranking semántico.
# Recomendados:
#   - qwen2.5:14b-instruct  → calidad alta, ~9 GB VRAM (default; NODO 16 GB OK)
#   - qwen2.5:7b-instruct   → más rápido, ~5 GB VRAM
#   - llama3.1:8b           → fallback genérico, peor en español/JSON
# Descargar con: ollama pull <modelo>
# Pensadero arranca y funciona sin Ollama; sólo cae el modo "Natural".
OLLAMA_MODEL=qwen2.5:14b-instruct

# Modelo VLM (Visión + Lenguaje) para describir imágenes durante el escaneo.
# Genera el _pensadero.json por carpeta con description, composition, tags,
# OCR, colores dominantes, etc.
#   - qwen2.5vl:7b   → ~6 GB VRAM, multilingüe, sweet spot (default)
#   - gemma3:12b     → ~7 GB VRAM, alternativa equivalente
# Descargar con: ollama pull <modelo>
VLM_MODEL=qwen2.5vl:7b

# Stage 2 re-ranking — usa el LLM como reranker semántico cuando Stage 1
# (matching literal) devuelve pocos resultados claros. Resuelve queries
# abstractas tipo "edificios" o "imagen exterior" donde la palabra no
# aparece literal en la metadata.
AI_RERANK_ENABLED=true
AI_RERANK_MIN_PRIMARY=5

# Registry de personas. Si están vacíos, se usan defaults dentro de
# backend/data/ y se crean automáticamente al guardar la primera persona
# desde la UI ("Personas" en el menú).
PERSONS_REGISTRY=
PERSONS_AVATARS_BASE=
